---
import '@fontsource-variable/inter';

interface Props {
	title?: string;
}

const { title = 'imitsu - Team secret manager' } = Astro.props;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="A team secret manager with a terminal UI. Manage secrets, share with teams, and export to .env files." />
		<title>{title}</title>
	</head>
	<body>
		<slot />
	</body>
</html>

<style is:global>
	*, *::before, *::after {
		margin: 0;
		padding: 0;
		box-sizing: border-box;
	}

	html, body {
		width: 100%;
		height: 100%;
		background: #0a0a0a;
		color: #ffffff;
	 font-family: 'Inter Variable', sans-serif;	
		-webkit-font-smoothing: antialiased;
		-moz-osx-font-smoothing: grayscale;
	}
</style>
